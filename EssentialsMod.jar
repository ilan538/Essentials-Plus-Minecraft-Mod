package com.jeNaam.essentialsmod;

import net.fabricmc.api.ModInitializer;
import net.fabricmc.fabric.api.client.rendering.v1.HudRenderCallback;
import com.jeNaam.essentialsmod.commands.HomeCommand;
import com.jeNaam.essentialsmod.overlay.HudOverlay;

public class EssentialsMod implements ModInitializer {
    @Override
    public void onInitialize() {
        System.out.println("Essentials Mod geladen!");
        HudRenderCallback.EVENT.register(new HudOverlay());
        HomeCommand.register();
    }
}